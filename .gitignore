# --- Entorno Python ---
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# --- Base vectorial (se regenera desde docs/, no se versiona) ---
data/chroma_db/*
!data/chroma_db/.gitkeep

# --- Datos sensibles del hotel ---
# Los documentos reales (procedimientos, directorio, referencias) solo existen
# en local. En GitHub se versiona únicamente el contenido de ejemplo (ejemplo_*).
docs/procedimientos/*
!docs/procedimientos/ejemplo_*.md
docs/referencias/*
!docs/referencias/ejemplo_*.md
docs/directorios/*
!docs/directorios/ejemplo_*.md
docs/**/*.real.*

# --- Métricas operativas (pueden contener preguntas reales del personal) ---
metrics/*.csv
metrics/*.log
metrics/*.json
!metrics/.gitkeep

# --- Config local con secretos, si los hubiera ---
.env
*.local.yaml

# --- IDE / SO ---
.vscode/
.idea/
.DS_Store
